---
import Base from '~/layouts/Base.astro';
import AboutPage from '~/components/AboutPage.astro';
import { useT } from '~/i18n/utils';

const lang = 'en';
const t = useT(lang);
const path = '/about';
---

<Base title={t('seo.about.title')} description={t('seo.about.description')} lang={lang} path={path}>
  <AboutPage lang={lang} />
</Base>
