---
import Base from '~/layouts/Base.astro';
import PartnerPage from '~/components/PartnerPage.astro';
import { useT } from '~/i18n/utils';

const lang = 'sk';
const t = useT(lang);
const path = '/sk/partner';
---

<Base title={t('seo.partner.title')} description={t('seo.partner.description')} lang={lang} path={path}>
  <PartnerPage lang={lang} />
</Base>
