---
import Base from '~/layouts/Base.astro';
import ServicesPage from '~/components/ServicesPage.astro';
import { useT } from '~/i18n/utils';

const lang = 'sk';
const t = useT(lang);
const path = '/sk/services';
---

<Base title={t('seo.services.title')} description={t('seo.services.description')} lang={lang} path={path}>
  <ServicesPage lang={lang} />
</Base>
