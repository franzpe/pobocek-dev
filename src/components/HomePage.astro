---
import type { Locale } from '~/i18n/utils';
import { getCollection } from 'astro:content';
import { useT, localizePath } from '~/i18n/utils';
import Hero from './Hero.astro';
import ProjectsGrid from './ProjectsGrid.astro';
import MyStory from './MyStory.astro';
import Contact from './Contact.astro';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const t = useT(lang);

const allProjects = await getCollection('projects');
const featured = allProjects
  .filter((p) => p.data.featured)
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));

const servicesHref = localizePath('/services', lang);
const partnerHref = localizePath('/partner', lang);
---

<Hero lang={lang} />

<!-- Positioning statement + stats (slim highlights — no project picks) -->
<div class="border-t border-violet bg-dark-violet">
  <div class="container mx-auto border-violet px-5 py-10 sm:border-x md:px-16 md:py-24">
    <span class="mb-4 inline-block text-xs font-bold uppercase tracking-widest text-lime"
      >{t('about.highlights.eyebrow')}</span
    >
    <h2 class="max-w-4xl text-4xl font-bold leading-tight text-violet md:text-6xl">
      {t('about.highlights.heading')}
    </h2>
    <p class="mt-6 max-w-3xl font-bold text-white md:mt-8 md:text-xl">
      {t('about.highlights.intro')}
    </p>

    <div class="mt-10 grid grid-cols-1 gap-6 md:mt-16 md:grid-cols-3 md:gap-10">
      <div>
        <p class="text-4xl font-bold text-lime md:text-6xl">{t('about.highlights.stat1Value')}</p>
        <p class="mt-2 text-xs font-bold uppercase tracking-wider text-white md:text-sm">
          {t('about.highlights.stat1Label')}
        </p>
      </div>
      <div>
        <p class="text-4xl font-bold text-lime md:text-6xl">{t('about.highlights.stat2Value')}</p>
        <p class="mt-2 text-xs font-bold uppercase tracking-wider text-white md:text-sm">
          {t('about.highlights.stat2Label')}
        </p>
      </div>
      <div>
        <p class="text-4xl font-bold text-lime md:text-6xl">{t('about.highlights.stat3Value')}</p>
        <p class="mt-2 text-xs font-bold uppercase tracking-wider text-white md:text-sm">
          {t('about.highlights.stat3Label')}
        </p>
      </div>
    </div>
  </div>
</div>

<!-- Partner callout — founder track (between Highlights and Services) -->
<div class="bg-lime border-t border-dark-violet">
  <div class="container mx-auto sm:border-x border-dark-violet px-5 md:px-16 py-10 md:py-20">
    <div class="max-w-3xl">
      <span class="inline-block text-xs font-bold uppercase tracking-widest text-dark-violet mb-4">{t('partner.homeCallout.eyebrow')}</span>
      <h2 class="text-3xl md:text-5xl font-bold leading-tight text-dark-violet">{t('partner.homeCallout.heading')}</h2>
      <p class="mt-6 text-dark-violet md:text-lg">{t('partner.homeCallout.body')}</p>
      <div class="mt-8">
        <a href={partnerHref} class="relative inline-flex items-center justify-center px-10 py-3 overflow-hidden font-bold text-lime bg-dark-violet rounded-full group">
          <span class="absolute w-0 h-0 transition-all duration-500 ease-out bg-violet rounded-full group-hover:w-[500px] group-hover:h-[500px]"></span>
          <span class="relative">{t('partner.homeCallout.cta')} →</span>
        </a>
      </div>
    </div>
  </div>
</div>

<!-- Services teaser (after Partner callout, before Projects) -->
<div class="bg-dark-violet border-t border-violet">
  <div class="container mx-auto sm:border-x border-violet px-5 md:px-16 py-10 md:py-20">
    <div class="max-w-3xl">
      <span class="inline-block text-xs font-bold uppercase tracking-widest text-lime mb-4">{t('services.teaser.eyebrow')}</span>
      <h2 class="text-4xl md:text-6xl font-bold leading-tight text-violet">{t('services.teaser.heading')}</h2>
      <p class="mt-6 text-white md:text-lg">{t('services.teaser.intro')}</p>
    </div>

    <div class="mt-10 md:mt-14 grid gap-6 md:gap-8 lg:grid-cols-3">
      <a href={`${servicesHref}#tier1`} class="group flex flex-col rounded-xl border border-violet p-6 md:p-8 transition-colors hover:border-lime">
        <span class="text-xs font-bold uppercase tracking-widest text-lime">{t('services.tier1.duration')}</span>
        <h3 class="mt-3 text-xl md:text-2xl font-bold text-violet">{t('services.tier1.name')}</h3>
        <p class="mt-3 text-2xl md:text-3xl font-bold text-lime">{t('services.tier1.price')}</p>
        <p class="mt-4 text-sm md:text-base text-white/80 flex-1">{t('services.tier1.tagline')}</p>
        <p class="mt-6 text-sm font-bold text-violet group-hover:text-lime transition-colors">{t('services.tier1.cta')} →</p>
      </a>
      <a href={`${servicesHref}#tier2`} class="group flex flex-col rounded-xl border border-violet p-6 md:p-8 transition-colors hover:border-lime">
        <span class="text-xs font-bold uppercase tracking-widest text-lime">{t('services.tier2.duration')}</span>
        <h3 class="mt-3 text-xl md:text-2xl font-bold text-violet">{t('services.tier2.name')}</h3>
        <p class="mt-3 text-2xl md:text-3xl font-bold text-lime">{t('services.tier2.price')}</p>
        <p class="mt-4 text-sm md:text-base text-white/80 flex-1">{t('services.tier2.tagline')}</p>
        <p class="mt-6 text-sm font-bold text-violet group-hover:text-lime transition-colors">{t('services.tier2.cta')} →</p>
      </a>
      <a href={`${servicesHref}#tier3`} class="group flex flex-col rounded-xl border border-violet p-6 md:p-8 transition-colors hover:border-lime">
        <span class="text-xs font-bold uppercase tracking-widest text-lime">{t('services.tier3.duration')}</span>
        <h3 class="mt-3 text-xl md:text-2xl font-bold text-violet">{t('services.tier3.name')}</h3>
        <p class="mt-3 text-2xl md:text-3xl font-bold text-lime">{t('services.tier3.price')}</p>
        <p class="mt-4 text-sm md:text-base text-white/80 flex-1">{t('services.tier3.tagline')}</p>
        <p class="mt-6 text-sm font-bold text-violet group-hover:text-lime transition-colors">{t('services.tier3.cta')} →</p>
      </a>
    </div>

    <div class="mt-10 md:mt-14 text-center md:text-left">
      <a href={servicesHref} class="relative inline-flex items-center justify-center px-12 py-4 overflow-hidden font-bold text-dark-violet bg-lime rounded-full group hover:bg-violet transition-colors">
        <span class="relative">{t('services.teaser.cta')} →</span>
      </a>
    </div>
  </div>
</div>

<ProjectsGrid lang={lang} projects={featured} defaultExpandedSlug="eviro" />
<MyStory lang={lang} />
<Contact lang={lang} variant="light" />
