---
import type { Locale } from '~/i18n/utils';
import { getCollection } from 'astro:content';
import { useT } from '~/i18n/utils';
import Hero from './Hero.astro';
import ProjectsGrid from './ProjectsGrid.astro';
import MyStory from './MyStory.astro';
import Contact from './Contact.astro';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const t = useT(lang);

const allProjects = await getCollection('projects');
const featured = allProjects
  .filter((p) => p.data.featured)
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
---

<Hero lang={lang} />
<ProjectsGrid lang={lang} projects={featured} defaultExpandedSlug="eviro" />

<!-- Highlights hook between the projects grid and My Story -->
<div class="border-t border-violet bg-dark-violet">
  <div class="container mx-auto border-violet px-5 py-10 sm:border-x md:px-16 md:py-32">
    <span class="mb-4 inline-block text-xs font-bold uppercase tracking-widest text-lime"
      >{t('about.highlights.eyebrow')}</span
    >
    <h2 class="max-w-4xl text-4xl font-bold leading-tight text-violet md:text-6xl">
      {t('about.highlights.heading')}
    </h2>
    <p class="mt-6 max-w-3xl font-bold text-white md:mt-8 md:text-xl">
      {t('about.highlights.intro')}
    </p>

    <div class="mt-10 grid grid-cols-2 gap-6 md:mt-16 md:grid-cols-4 md:gap-10">
      <div>
        <p class="text-4xl font-bold text-lime md:text-6xl">{t('about.highlights.stat1Value')}</p>
        <p class="mt-2 text-xs font-bold uppercase tracking-wider text-white md:text-sm">
          {t('about.highlights.stat1Label')}
        </p>
      </div>
      <div>
        <p class="text-4xl font-bold text-lime md:text-6xl">{t('about.highlights.stat2Value')}</p>
        <p class="mt-2 text-xs font-bold uppercase tracking-wider text-white md:text-sm">
          {t('about.highlights.stat2Label')}
        </p>
      </div>
      <div>
        <p class="text-4xl font-bold text-lime md:text-6xl">{t('about.highlights.stat3Value')}</p>
        <p class="mt-2 text-xs font-bold uppercase tracking-wider text-white md:text-sm">
          {t('about.highlights.stat3Label')}
        </p>
      </div>
      <div>
        <p class="text-4xl font-bold text-lime md:text-6xl">{t('about.highlights.stat4Value')}</p>
        <p class="mt-2 text-xs font-bold uppercase tracking-wider text-white md:text-sm">
          {t('about.highlights.stat4Label')}
        </p>
      </div>
    </div>

    <div class="mt-12 grid gap-6 md:mt-20 md:grid-cols-3 md:gap-8">
      <div class="rounded-xl border border-violet p-6 md:p-8">
        <h3 class="mb-3 text-xl font-bold text-violet md:text-2xl">
          {t('about.highlights.pick1Title')}
        </h3>
        <p class="text-sm text-white md:text-base">{t('about.highlights.pick1Body')}</p>
      </div>
      <div class="rounded-xl border border-violet p-6 md:p-8">
        <h3 class="mb-3 text-xl font-bold text-violet md:text-2xl">
          {t('about.highlights.pick2Title')}
        </h3>
        <p class="text-sm text-white md:text-base">{t('about.highlights.pick2Body')}</p>
      </div>
      <div class="rounded-xl border border-violet p-6 md:p-8">
        <h3 class="mb-3 text-xl font-bold text-violet md:text-2xl">
          {t('about.highlights.pick3Title')}
        </h3>
        <p class="text-sm text-white md:text-base">{t('about.highlights.pick3Body')}</p>
      </div>
    </div>
  </div>
</div>

<MyStory lang={lang} />
<Contact lang={lang} variant="light" />
