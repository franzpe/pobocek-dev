---
import type { Locale } from '~/i18n/utils';
import { useT } from '~/i18n/utils';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const t = useT(lang);
---

<article class="bg-beige border-b border-dark-violet">
  <div class="py-10 md:py-20 px-5 md:px-16 container mx-auto text-dark-violet sm:border-x border-dark-violet">
    <h1 class="text-4xl md:text-6xl font-bold">{t('privacy.heading')}</h1>
    <p class="mt-4 text-medium-grey">{t('privacy.lastUpdated')}</p>
  </div>
</article>

<div class="bg-beige border-b border-dark-violet">
  <div class="py-10 md:py-20 px-5 md:px-16 container mx-auto sm:border-x border-dark-violet text-dark-violet">
    <div class="max-w-4xl">
      <p class="text-lg md:text-xl leading-relaxed mb-10">{t('privacy.intro')}</p>

      <h2 class="text-2xl md:text-3xl font-bold mt-10 mb-4">{t('privacy.whoHeading')}</h2>
      <p class="mb-8 leading-relaxed">{t('privacy.whoBody')}</p>

      <h2 class="text-2xl md:text-3xl font-bold mt-10 mb-4">{t('privacy.dataHeading')}</h2>
      <p class="mb-4 leading-relaxed">{t('privacy.dataIntro')}</p>
      <div class="mb-8">
        <h3 class="font-bold text-lg mb-2">{t('privacy.data1Title')}</h3>
        <p class="leading-relaxed mb-6">{t('privacy.data1Body')}</p>
        <h3 class="font-bold text-lg mb-2">{t('privacy.data2Title')}</h3>
        <p class="leading-relaxed">{t('privacy.data2Body')}</p>
      </div>

      <h2 class="text-2xl md:text-3xl font-bold mt-10 mb-4">{t('privacy.cookiesHeading')}</h2>
      <p class="mb-8 leading-relaxed">{t('privacy.cookiesBody')}</p>

      <h2 class="text-2xl md:text-3xl font-bold mt-10 mb-4">{t('privacy.rightsHeading')}</h2>
      <p class="mb-8 leading-relaxed">{t('privacy.rightsBody')}</p>

      <h2 class="text-2xl md:text-3xl font-bold mt-10 mb-4">{t('privacy.thirdHeading')}</h2>
      <p class="mb-8 leading-relaxed">{t('privacy.thirdBody')}</p>

      <h2 class="text-2xl md:text-3xl font-bold mt-10 mb-4">{t('privacy.changesHeading')}</h2>
      <p class="mb-8 leading-relaxed">{t('privacy.changesBody')}</p>

      <h2 class="text-2xl md:text-3xl font-bold mt-10 mb-4">{t('privacy.contactHeading')}</h2>
      <p class="mb-4 leading-relaxed">{t('privacy.contactBody')}</p>
    </div>
  </div>
</div>
