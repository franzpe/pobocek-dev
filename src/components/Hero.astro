---
import type { Locale } from '~/i18n/utils';
import { useT } from '~/i18n/utils';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const t = useT(lang);
---

<div id="hero-section" class="relative bg-dark-violet">
  <canvas id="hero-dots" class="pointer-events-none absolute inset-0 z-30 w-full h-full"></canvas>
  <div
    class="container mx-auto flex flex-wrap items-stretch border-violet px-5 pt-4 pb-10 text-violet sm:border-x md:px-16 md:py-32"
  >
    <!-- Text column (left on desktop). On mobile this is the only column — photo is embedded inside. -->
    <div class="flex w-full items-center lg:w-2/3 xl:w-1/2">
      <div class="relative z-20 w-full text-center lg:text-left">

        <!-- Name -->
        <h1 class="text-5xl font-bold md:text-8xl lg:text-[6rem] xl:text-[7.5rem] leading-tight">{t('hero.greeting')}</h1>

        <!-- Mobile-only photo: sits between name and tagline, hidden on desktop -->
        <div class="relative mx-auto mt-6 w-44 overflow-hidden rounded-2xl border border-violet/20 lg:hidden">
          <img
            class="w-full h-56 object-cover object-top"
            src="/assets/images/frantisekpobocek.png"
            alt={t('hero.photoAlt')}
          />
          <div
            class="pointer-events-none absolute inset-0"
            style="background: linear-gradient(to bottom, transparent 55%, rgba(26,26,51,0.6) 80%, rgba(26,26,51,1) 100%);"
          ></div>
        </div>

        <!-- Tagline -->
        <h2 class="pt-6 text-lg md:text-xl md:leading-[2rem] lg:max-w-xl">{t('hero.tagline')}</h2>
        <p class="pt-3 text-sm md:text-base font-bold text-lime lg:max-w-xl">{t('hero.tagline2')}</p>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row gap-4 pt-10 justify-center lg:justify-start">
          <a href="/work" class="inline-flex items-center justify-center gap-2 rounded-full bg-violet px-8 py-3 font-bold text-dark-violet transition-colors hover:bg-lime">
            {t('hero.ctaWork')} →
          </a>
          <a href="#contact" class="inline-flex items-center justify-center gap-2 rounded-full border border-violet px-8 py-3 font-bold text-violet transition-colors hover:border-lime hover:text-lime">
            {t('hero.ctaContact')}
          </a>
        </div>

        <!-- Trust signals -->
        <div class="flex flex-wrap justify-center lg:justify-start gap-x-3 gap-y-1 pt-8 text-sm text-violet/50">
          <span>10+ years</span>
          <span aria-hidden="true">·</span>
          <span>18+ projects shipped</span>
          <span aria-hidden="true">·</span>
          <span>EU clients</span>
        </div>

      </div>
    </div>

    <!-- Desktop-only photo column (right side) -->
    <div class="relative z-20 hidden lg:block lg:w-1/3 xl:w-1/2">
      <div class="relative w-full overflow-hidden">
        <img
          class="relative z-0 w-full h-auto"
          src="/assets/images/frantisekpobocek.png"
          alt={t('hero.photoAlt')}
        />
        <div
          class="pointer-events-none absolute inset-0 z-[1]"
          style="background: radial-gradient(ellipse 65% 75% at 58% 38%, transparent 32%, rgba(26,26,51,0.55) 65%, rgba(26,26,51,0.95) 100%);"
        ></div>
      </div>
    </div>
  </div>
</div>

<script>
  const canvas = document.getElementById('hero-dots') as HTMLCanvasElement | null;
  const section = document.getElementById('hero-section') as HTMLElement | null;
  if (canvas && section) {
    const ctx = canvas.getContext('2d')!;
    const DOT_COLOR = '#C4B7F1';
    const DOT_RADIUS_BASE = 3.5;
    const DOT_RADIUS_MAX = 11;
    const SPACING = 36;
    const INFLUENCE_RADIUS = 100;

    let mouse = { x: -9999, y: -9999 };
    let dots: { x: number; y: number; r: number; targetR: number }[] = [];

    function buildGrid() {
      dots = [];
      const cols = Math.ceil(canvas!.width / SPACING) + 1;
      const rows = Math.ceil(canvas!.height / SPACING) + 1;
      for (let row = 0; row < rows; row++) {
        for (let col = 0; col < cols; col++) {
          dots.push({ x: col * SPACING, y: row * SPACING, r: 0, targetR: 0 });
        }
      }
    }

    function resize() {
      canvas!.width = section!.offsetWidth;
      canvas!.height = section!.offsetHeight;
      buildGrid();
    }

    function draw() {
      ctx.clearRect(0, 0, canvas!.width, canvas!.height);
      for (const dot of dots) {
        const dx = dot.x - mouse.x;
        const dy = dot.y - mouse.y;
        const dist = Math.sqrt(dx * dx + dy * dy);
        const proximity = Math.max(0, 1 - dist / INFLUENCE_RADIUS);
        dot.targetR = DOT_RADIUS_BASE + (DOT_RADIUS_MAX - DOT_RADIUS_BASE) * proximity * proximity;
        dot.r += (dot.targetR - dot.r) * 0.18;

        if (dot.r < 0.1) continue;

        ctx.beginPath();
        ctx.arc(dot.x, dot.y, dot.r, 0, Math.PI * 2);
        ctx.fillStyle = DOT_COLOR;
        ctx.globalAlpha = proximity * proximity;
        ctx.fill();
      }
      ctx.globalAlpha = 1;
      requestAnimationFrame(draw);
    }

    section.addEventListener('mousemove', (e) => {
      const rect = section!.getBoundingClientRect();
      mouse.x = e.clientX - rect.left;
      mouse.y = e.clientY - rect.top;
    });

    section.addEventListener('mouseleave', () => {
      mouse.x = -9999;
      mouse.y = -9999;
    });

    const ro = new ResizeObserver(resize);
    ro.observe(section);
    resize();
    draw();
  }
</script>
