---
import type { Locale } from '~/i18n/utils';
import { useT } from '~/i18n/utils';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const t = useT(lang);
---

<div class="bg-dark-violet">
  <div class="flex flex-wrap items-center py-10 md:py-40 px-5 md:px-16 container mx-auto text-violet sm:border-x border-violet">
    <div class="w-full lg:w-2/3 xl:w-1/2">
      <h1 class="text-4xl md:text-8xl font-bold md:leading-[8rem]">{t('hero.greeting')}</h1>
      <h2 class="text-2xl pt-6 md:leading-[3rem] md:w-96">{t('hero.tagline')}</h2>
    </div>
    <div class="mt-6 lg:mt-0 w-full lg:w-1/3 xl:w-1/2 relative">
      <img class="w-full absolute bottom-0 z-10" src="/assets/images/bullets.svg" alt={t('hero.bulletsAlt')} />
      <img class="w-full relative z-0" src="/assets/images/frantisekpobocek.jpg" alt={t('hero.photoAlt')} />
    </div>
  </div>
</div>
