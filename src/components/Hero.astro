---
import type { Locale } from '~/i18n/utils';
import { useT } from '~/i18n/utils';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const t = useT(lang);
---

<div class="bg-dark-violet">
  <div class="flex flex-wrap items-stretch py-10 md:py-32 px-5 md:px-16 container mx-auto text-violet sm:border-x border-violet gap-y-10">
    <div class="w-full lg:w-2/3 xl:w-1/2 flex items-center">
      <div>
        <h1 class="text-4xl md:text-8xl font-bold md:leading-[8rem]">{t('hero.greeting')}</h1>
        <h2 class="text-xl md:text-2xl pt-6 md:leading-[2.25rem] max-w-xl">{t('hero.tagline')}</h2>
      </div>
    </div>

    <div class="w-full lg:w-1/3 xl:w-1/2 relative min-h-[400px] lg:min-h-[500px]">
      <div class="relative w-full h-full overflow-hidden">
        <img
          class="absolute inset-0 w-full h-full object-cover object-[60%_25%] z-0"
          src="/assets/images/frantisekpobocek.jpg"
          alt={t('hero.photoAlt')}
        />
        <div
          class="absolute inset-0 pointer-events-none z-[1]"
          style="background: radial-gradient(ellipse 65% 75% at 58% 38%, transparent 32%, rgba(26,26,51,0.55) 65%, rgba(26,26,51,0.95) 100%);"
        ></div>
        <img
          class="absolute inset-0 w-full h-full object-cover z-10 pointer-events-none"
          src="/assets/images/bullets.svg"
          alt={t('hero.bulletsAlt')}
        />
      </div>
    </div>
  </div>
</div>
