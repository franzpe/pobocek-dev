---
import type { Locale } from '~/i18n/utils';
import { useT } from '~/i18n/utils';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const t = useT(lang);
---

<div class="bg-dark-violet">
  <div
    class="container mx-auto flex flex-wrap items-stretch gap-y-10 border-violet px-5 py-10 text-violet sm:border-x md:px-16 md:py-32"
  >
    <div class="flex w-full items-center lg:w-2/3 xl:w-1/2">
      <div>
        <h1 class="text-4xl font-bold md:text-8xl md:leading-[8rem]">{t('hero.greeting')}</h1>
        <h2 class="max-w-xl pt-6 text-xl md:text-2xl md:leading-[2.25rem]">{t('hero.tagline')}</h2>
      </div>
    </div>

    <div class="relative w-full lg:w-1/3 xl:w-1/2">
      <div class="relative w-full overflow-hidden">
        <img
          class="relative z-0 w-full h-auto"
          src="/assets/images/frantisekpobocek.png"
          alt={t('hero.photoAlt')}
        />
        <div
          class="pointer-events-none absolute inset-0 z-[1]"
          style="background: radial-gradient(ellipse 65% 75% at 58% 38%, transparent 32%, rgba(26,26,51,0.55) 65%, rgba(26,26,51,0.95) 100%);"
        >
        </div>
        <img
          class="pointer-events-none absolute inset-0 z-10 h-full w-full object-cover"
          src="/assets/images/bullets.svg"
          alt={t('hero.bulletsAlt')}
        />
      </div>
    </div>
  </div>
</div>
