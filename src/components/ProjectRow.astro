---
import type { Locale } from '~/i18n/utils';
import { useT, localizePath } from '~/i18n/utils';

interface Props {
  lang: Locale;
  title: string;
  year: string;
  description?: string;
  image?: string;
  logo?: string;
  slug: string;
  defaultExpanded?: boolean;
}

const { lang, title, year, description, image, logo, slug, defaultExpanded = false } = Astro.props;
const t = useT(lang);
const detailHref = localizePath(`/work/${slug}`, lang);

const rowId = `project-row-${slug}`;
const bodyId = `project-body-${slug}`;
---

<div class="border-b border-violet bg-dark-violet" data-project-row id={rowId}>
  <div
    class={`container mx-auto flex flex-wrap sm:border-x border-violet transition-colors ${defaultExpanded ? 'bg-lime' : 'bg-dark-violet'}`}
    data-project-header
    data-expanded={defaultExpanded ? 'true' : 'false'}
  >
    <div class="w-2/4 md:w-2/3">
      <p class={`text-s md:text-xl font-bold py-4 lg:py-12 px-5 lg:px-16 ml-0 lg:ml-4 transition-colors ${defaultExpanded ? 'text-dark-violet' : 'text-white'}`} data-project-title>{title}</p>
    </div>
    <div class={`w-1/4 md:w-1/6 border-x border-violet`}>
      <p class={`text-s md:text-xl font-bold text-center py-4 lg:py-12 px-2 lg:px-16 transition-colors ${defaultExpanded ? 'text-dark-violet' : 'text-white'}`} data-project-year>{year}</p>
    </div>
    <button
      type="button"
      class="w-1/4 md:w-1/6 flex items-center justify-center cursor-pointer py-4 lg:py-12 hover:opacity-70 transition-opacity"
      data-project-toggle
      aria-expanded={defaultExpanded ? 'true' : 'false'}
      aria-controls={bodyId}
      aria-label={`${t('card.readMore')} ${title}`}
    >
      <img
        src="/assets/images/arrow-right.svg"
        alt=""
        aria-hidden="true"
        class={`transition-transform duration-300 ${defaultExpanded ? 'rotate-90' : ''}`}
        data-project-arrow
      />
    </button>
  </div>

  <div
    id={bodyId}
    data-project-body
    class={`overflow-hidden transition-all duration-300 ease-out ${defaultExpanded ? 'max-h-[2000px]' : 'max-h-0'}`}
  >
    <div class="container mx-auto bg-lime sm:border-x border-violet flex flex-wrap">
      <div class="w-full md:w-2/5 border-t border-dark-violet ml-4 md:ml-16 flex items-center">
        {logo ? (
          <img class="py-6 md:py-12 w-full max-w-xs md:max-w-sm max-h-72 md:max-h-[22rem] object-contain" src={logo} alt={title} />
        ) : image ? (
          <img class="py-6 md:py-12 w-full max-w-xs md:max-w-sm max-h-72 md:max-h-[22rem] object-contain" src={image} alt={title} />
        ) : null}
      </div>
      <div class="flex-1 md:border-t border-dark-violet py-6 md:py-14 px-5 md:px-20">
        {description && <p class="font-bold text-dark-violet">{description}</p>}
        <a
          href={detailHref}
          class="mt-7 relative inline-flex items-center justify-center px-12 py-4 overflow-hidden font-bold text-white bg-dark-violet rounded-full group"
        >
          <span class="absolute w-0 h-0 transition-all duration-500 ease-out bg-violet rounded-full group-hover:w-56 group-hover:h-56"></span>
          <span class="relative">{t('card.readMore')}</span>
        </a>
      </div>
    </div>
  </div>
</div>
