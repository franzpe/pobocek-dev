---
import type { Locale } from '~/i18n/utils';
import { useT, localizePath } from '~/i18n/utils';

interface Props {
  lang: Locale;
  title: string;
  year: string;
  description?: string;
  image?: string;
  slug: string;
  highlight?: boolean;
}

const { lang, title, year, description, image, slug, highlight = false } = Astro.props;
const t = useT(lang);
const detailHref = localizePath(`/work/${slug}`, lang);

const barBg = highlight ? 'bg-lime' : '';
const textColor = highlight ? 'text-dark-violet' : 'text-white';
const borderColor = 'border-violet';
---

<div class="border-b border-violet">
  <div class={`flex flex-wrap container mx-auto sm:border-x ${borderColor} ${barBg}`}>
    <div class="w-2/4 md:w-2/3">
      <p class={`text-s md:text-xl font-bold ${textColor} py-4 lg:py-12 px-5 lg:px-16 ml-0 lg:ml-4`}>{title}</p>
    </div>
    <div class={`w-1/4 md:w-1/6 ${borderColor} border-x`}>
      <p class={`text-s md:text-xl font-bold ${textColor} text-center py-4 lg:py-12 px-2 lg:px-16`}>{year}</p>
    </div>
    <a href={detailHref} class="w-1/4 md:w-1/6 cursor-pointer flex items-center justify-center" aria-label={`${t('card.readMore')} ${title}`}>
      <img class="text-center py-4 lg:py-12 mx-auto" src={highlight ? '/assets/images/arrow-bottom.svg' : '/assets/images/arrow-right.svg'} alt="" aria-hidden="true" />
    </a>
  </div>

  {highlight && description && image && (
    <div class="bg-lime flex flex-wrap container mx-auto">
      <div class="w-full md:w-2/6 border-t border-dark-violet ml-4 md:ml-16">
        <img class="py-6 md:py-14 max-h-48 object-contain" src={image} alt={title} />
      </div>
      <div class="flex-1 md:border-t border-dark-violet py-6 md:py-14 px-5 md:px-20">
        <p class="font-bold text-dark-violet">{description}</p>
        <a href={detailHref} class="mt-7 relative inline-flex items-center justify-center px-12 py-4 overflow-hidden font-bold text-white bg-dark-violet rounded-full group">
          <span class="absolute w-0 h-0 transition-all duration-500 ease-out bg-violet rounded-full group-hover:w-56 group-hover:h-56"></span>
          <span class="relative">{t('card.readMore')}</span>
        </a>
      </div>
    </div>
  )}
</div>
