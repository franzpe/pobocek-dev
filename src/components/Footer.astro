---
import type { Locale } from '~/i18n/utils';
import { useT, localizePath } from '~/i18n/utils';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const t = useT(lang);
const year = new Date().getFullYear();
const privacyHref = localizePath('/privacy', lang);
---

<footer class="bg-beige">
  <div class="flex flex-wrap justify-between md:justify-around container mx-auto sm:border-x border-dark-violet py-6 md:py-14 px-5 md:px-0 items-center gap-4">
    <div>
      <a class="text-xs font-bold text-dark-violet underline hover:text-violet transition-colors" href={privacyHref}>
        {t('footer.privacy')}
      </a>
    </div>
    <div>
      <ul class="flex gap-3 items-center">
        <li>
          <a href="https://linkedin.com/in/frantisek-pobocek-06819913b" target="_blank" rel="noopener" aria-label="LinkedIn">
            <img class="opacity-60 hover:opacity-100 transition-opacity duration-200" src="/assets/images/linkedin-dv.svg" alt="" width="24" height="24" />
          </a>
        </li>
        <li>
          <a href="https://github.com/franzpe" target="_blank" rel="noopener" aria-label="GitHub">
            <img class="opacity-60 hover:opacity-100 transition-opacity duration-200" src="/assets/images/github-sign-dv.svg" alt="" width="24" height="24" />
          </a>
        </li>
      </ul>
    </div>
    <div>
      <p class="text-xs text-dark-violet font-bold">{year}. {t('footer.copyright')}</p>
    </div>
  </div>
</footer>
