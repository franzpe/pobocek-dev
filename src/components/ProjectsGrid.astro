---
import type { Locale } from '~/i18n/utils';
import type { CollectionEntry } from 'astro:content';
import { useT, localizePath } from '~/i18n/utils';
import ProjectRow from './ProjectRow.astro';

interface Props {
  lang: Locale;
  projects: CollectionEntry<'projects'>[];
  defaultExpandedSlug?: string;
}

const { lang, projects, defaultExpandedSlug } = Astro.props;
const t = useT(lang);
const workHref = localizePath('/work', lang);
---

<div class="bg-dark-violet border-t border-violet" data-projects-grid>
  {projects.map((p) => (
    <ProjectRow
      lang={lang}
      title={p.data.title[lang]}
      year={p.data.date.slice(0, 4)}
      description={p.data.description[lang]}
      image={p.data.image}
      logo={p.data.logo}
      slug={p.id}
      defaultExpanded={p.id === defaultExpandedSlug}
    />
  ))}
</div>

<div class="border-b border-violet bg-dark-violet">
  <div class="container mx-auto sm:border-x border-violet">
    <div class="py-4 md:py-12 px-5 md:px-16 ml-0 md:ml-4">
      <a href={workHref} class="relative inline-flex items-center justify-center px-12 py-4 overflow-hidden border-lime border font-bold text-lime bg-dark-violet rounded-full group hover:text-dark-violet">
        <span class="absolute w-0 h-0 transition-all duration-500 ease-out bg-lime rounded-full group-hover:w-56 group-hover:h-56"></span>
        <span class="relative">{t('projectsHome.seeAll')}</span>
      </a>
      <span class="hidden sm:inline text-l sm:text-4xl lg:text-6xl text-lime pt-3.5 sm:pt-0 md:tracking-[.3rem] lg:tracking-[.6rem] xl:tracking-[1.3rem] 2xl:tracking-[1.8rem] float-right">////////////////////////</span>
    </div>
  </div>
</div>

<script>
  const grid = document.querySelector('[data-projects-grid]');
  if (grid) {
    grid.querySelectorAll<HTMLButtonElement>('[data-project-toggle]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const row = btn.closest('[data-project-row]');
        if (!row) return;
        const header = row.querySelector<HTMLElement>('[data-project-header]');
        const body = row.querySelector<HTMLElement>('[data-project-body]');
        const title = row.querySelector<HTMLElement>('[data-project-title]');
        const year = row.querySelector<HTMLElement>('[data-project-year]');
        const arrow = row.querySelector<HTMLElement>('[data-project-arrow]');
        if (!header || !body) return;

        const expanded = header.getAttribute('data-expanded') === 'true';
        const next = !expanded;
        header.setAttribute('data-expanded', String(next));
        btn.setAttribute('aria-expanded', String(next));

        if (next) {
          header.classList.remove('bg-dark-violet');
          header.classList.add('bg-lime');
          title?.classList.remove('text-white');
          title?.classList.add('text-dark-violet');
          year?.classList.remove('text-white');
          year?.classList.add('text-dark-violet');
          body.classList.remove('grid-rows-[0fr]');
          body.classList.add('grid-rows-[1fr]');
          arrow?.classList.add('rotate-90');
        } else {
          header.classList.add('bg-dark-violet');
          header.classList.remove('bg-lime');
          title?.classList.add('text-white');
          title?.classList.remove('text-dark-violet');
          year?.classList.add('text-white');
          year?.classList.remove('text-dark-violet');
          body.classList.add('grid-rows-[0fr]');
          body.classList.remove('grid-rows-[1fr]');
          arrow?.classList.remove('rotate-90');
        }
      });
    });
  }
</script>
