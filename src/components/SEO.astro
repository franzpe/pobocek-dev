---
import type { Locale } from '~/i18n/utils';
import { alternatePath } from '~/i18n/utils';

interface Props {
  title: string;
  description: string;
  lang: Locale;
  path: string;
  ogImage?: string;
}

const { title, description, lang, path, ogImage = '/assets/images/frantisekpobocek.png' } = Astro.props;
const site = Astro.site ?? new URL('https://pobocek.dev');
const canonical = new URL(path, site).toString();
const alternate = alternatePath(path, lang);
const alternateUrl = new URL(alternate, site).toString();
const ogImageUrl = new URL(ogImage, site).toString();
---

<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />

<link rel="alternate" hreflang={lang === 'en' ? 'en' : 'sk'} href={canonical} />
<link rel="alternate" hreflang={lang === 'en' ? 'sk' : 'en'} href={alternateUrl} />
<link rel="alternate" hreflang="x-default" href={new URL(lang === 'en' ? path : alternate, site).toString()} />

<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:type" content="website" />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={ogImageUrl} />
<meta property="og:locale" content={lang === 'en' ? 'en_US' : 'sk_SK'} />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageUrl} />
