---
import type { Locale } from '~/i18n/utils';
import { useT, localizePath } from '~/i18n/utils';
import LanguageSwitcher from './LanguageSwitcher.astro';

interface Props {
  lang: Locale;
  path: string;
  variant?: 'dark' | 'light';
}

const { lang, path, variant = 'dark' } = Astro.props;
const t = useT(lang);

const isDark = variant === 'dark';
const topBarBg = isDark ? 'bg-dark-violet border-b border-violet/40' : 'bg-beige border-b border-dark-violet/40';
const navBg = isDark ? 'bg-dark-violet sm:border-b border-violet' : 'bg-beige sm:border-b border-dark-violet';
const borderColor = isDark ? 'border-violet' : 'border-dark-violet';
const textColor = isDark ? 'text-white' : 'text-dark-violet';
const socialHover = isDark
  ? 'transition-opacity duration-200 hover:opacity-60'
  : 'opacity-60 transition-opacity duration-200 hover:opacity-100';
const toggleLine = isDark ? 'bg-white' : 'bg-dark-violet';
const mobileMenuBg = isDark ? 'bg-dark-violet' : 'bg-beige';

const logoSrc = isDark ? '/assets/images/logo-white.svg' : '/assets/images/logo-black.svg';
const iconSuffix = isDark ? '' : '-dv';

const home = localizePath('/', lang);
const work = localizePath('/work', lang);
const about = localizePath('/about', lang);
const contactAnchor = `${home}#contact`;
---

<div class={`hidden md:block ${topBarBg}`}>
  <div class={`container mx-auto flex justify-end items-center sm:border-x ${borderColor} py-2 px-5 md:px-16`}>
    <LanguageSwitcher lang={lang} path={path} variant={isDark ? 'light' : 'dark'} />
  </div>
</div>

<nav class={navBg} id="site-nav">
  <div class={`container mx-auto flex items-center justify-between sm:border-x ${borderColor} py-3 md:py-4 px-5 md:px-16`}>
    <a href={home} aria-label="pobocek.dev home" class="shrink-0">
      <img
        src={logoSrc}
        alt={t('nav.logoAlt')}
        class="h-[90px] md:h-[132px] w-auto"
        width="258"
        height="126"
      />
    </a>

    <button
      type="button"
      id="mobile-menu-toggle"
      class="md:hidden flex flex-col gap-1.5 p-2 focus:outline-none"
      aria-label="Toggle menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span class={`block w-7 h-0.5 ${toggleLine} transition-transform`}></span>
      <span class={`block w-7 h-0.5 ${toggleLine} transition-opacity`}></span>
      <span class={`block w-7 h-0.5 ${toggleLine} transition-transform`}></span>
    </button>

    <ul class={`hidden md:flex flex-wrap items-center font-bold z-10 ${textColor}`}>
      <li class="px-3"><a class="px-6 py-6 hover:text-violet" href={contactAnchor}>{t('nav.getInTouch')}</a></li>
      <li class="px-3"><a class="px-6 py-6 hover:text-violet" href={work}>{t('nav.work')}</a></li>
      <li class="px-3"><a class="px-6 py-6 hover:text-violet" href={about}>{t('nav.about')}</a></li>
      <li>
        <ul class="flex gap-3 items-center ml-3">
          <li><a href="https://linkedin.com/in/frantisek-pobocek-06819913b" target="_blank" rel="noopener" aria-label="LinkedIn"><img class={socialHover} src={`/assets/images/linkedin${iconSuffix}.svg`} alt="" width="24" height="24" /></a></li>
          <li><a href="https://github.com/franzpe" target="_blank" rel="noopener" aria-label="GitHub"><img class={socialHover} src={`/assets/images/github-sign${iconSuffix}.svg`} alt="" width="24" height="24" /></a></li>
        </ul>
      </li>
    </ul>
  </div>

  <div id="mobile-menu" class={`hidden md:hidden ${mobileMenuBg} border-t ${borderColor}`}>
    <ul class={`flex flex-col font-bold text-lg ${textColor}`}>
      <li><a class={`block px-8 py-5 hover:text-violet border-b ${borderColor}`} href={contactAnchor}>{t('nav.getInTouch')}</a></li>
      <li><a class={`block px-8 py-5 hover:text-violet border-b ${borderColor}`} href={work}>{t('nav.work')}</a></li>
      <li><a class={`block px-8 py-5 hover:text-violet border-b ${borderColor}`} href={about}>{t('nav.about')}</a></li>
      <li class={`px-8 py-5 border-b ${borderColor}`}><LanguageSwitcher lang={lang} path={path} variant={isDark ? 'light' : 'dark'} /></li>
      <li class="px-8 py-5">
        <ul class="flex gap-5 items-center">
          <li><a href="https://linkedin.com/in/frantisek-pobocek-06819913b" target="_blank" rel="noopener" aria-label="LinkedIn"><img class={socialHover} src={`/assets/images/linkedin${iconSuffix}.svg`} alt="" width="28" height="28" /></a></li>
          <li><a href="https://github.com/franzpe" target="_blank" rel="noopener" aria-label="GitHub"><img class={socialHover} src={`/assets/images/github-sign${iconSuffix}.svg`} alt="" width="28" height="28" /></a></li>
        </ul>
      </li>
    </ul>
  </div>
</nav>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      const expanded = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!expanded));
      menu.classList.toggle('hidden');
      const [a, b, c] = toggle.querySelectorAll('span');
      if (!expanded) {
        a?.classList.add('translate-y-2', 'rotate-45');
        b?.classList.add('opacity-0');
        c?.classList.add('-translate-y-2', '-rotate-45');
      } else {
        a?.classList.remove('translate-y-2', 'rotate-45');
        b?.classList.remove('opacity-0');
        c?.classList.remove('-translate-y-2', '-rotate-45');
      }
    });
  }
</script>
